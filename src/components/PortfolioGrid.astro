---
import { leftColumn, rightColumn, type Project } from '../data/projects';

function getPlaceholderText(title: string) {
  return title.split(" ").map(w => w[0]).join("").slice(0, 3);
}
---

<div class="flex flex-col items-start w-full">
  <div class="flex flex-col md:flex-row gap-8 justify-center px-4 md:px-6 w-full">
    <!-- Left Column (hidden on mobile, merged into single) -->
    <div class="hidden md:flex flex-1 flex-col gap-8 min-w-0">
      {leftColumn.map((item: Project) => (
        <a href={`/work/${item.slug}`} class="project-card group flex flex-col gap-0.5 h-[353px] w-full cursor-none no-underline">
          <div class="flex-1 min-h-0 w-full rounded-lg overflow-hidden relative transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.03]">
            {item.image ? (
              <img src={item.image} alt={item.title} class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <div class="bg-[#d1d5db] absolute inset-0 flex items-center justify-center">
                <span class="text-[#9ca3af] text-sm">{getPlaceholderText(item.title)}</span>
              </div>
            )}
          </div>
          <div class="flex items-start justify-between h-[19px] text-sm md:text-base whitespace-nowrap w-full">
            <p class="font-medium text-[#374151] font-['Inter']">{item.title}</p>
            <p class="text-[#6b7280] uppercase font-['Geist_Mono']">{`${item.company} • ${item.year}`}</p>
          </div>
        </a>
      ))}
    </div>

    <!-- Right Column (hidden on mobile, merged into single) -->
    <div class="hidden md:flex flex-1 flex-col gap-8 min-w-0">
      {rightColumn.map((item: Project) => (
        <a href={`/work/${item.slug}`} class="project-card group flex flex-col gap-0.5 flex-1 w-full cursor-none no-underline">
          <div class="flex-1 min-h-0 w-full rounded-lg overflow-hidden relative transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.03]">
            {item.image ? (
              <img src={item.image} alt={item.title} class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <div class="bg-[#d1d5db] absolute inset-0 flex items-center justify-center">
                <span class="text-[#9ca3af] text-sm">{getPlaceholderText(item.title)}</span>
              </div>
            )}
          </div>
          <div class="flex items-start justify-between h-[19px] text-sm md:text-base whitespace-nowrap w-full">
            <p class="font-medium text-[#374151] font-['Inter']">{item.title}</p>
            <p class="text-[#6b7280] uppercase font-['Geist_Mono']">{`${item.company} • ${item.year}`}</p>
          </div>
        </a>
      ))}
    </div>

    <!-- Mobile: Single column, interleaved -->
    <div class="flex md:hidden flex-col gap-8 w-full">
      {leftColumn.map((item: Project, i: number) => (
        <>
          <a href={`/work/${item.slug}`} class="project-card group flex flex-col gap-0.5 w-full cursor-none no-underline">
            <div class="h-[250px] w-full rounded-lg overflow-hidden relative transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.03]">
              {item.image ? (
                <img src={item.image} alt={item.title} class="absolute inset-0 w-full h-full object-cover" />
              ) : (
                <div class="bg-[#d1d5db] absolute inset-0 flex items-center justify-center">
                  <span class="text-[#9ca3af] text-sm">{getPlaceholderText(item.title)}</span>
                </div>
              )}
            </div>
            <div class="flex flex-col gap-0.5 text-sm w-full">
              <p class="font-medium text-[#374151] font-['Inter']">{item.title}</p>
              <p class="text-[#6b7280] uppercase font-['Geist_Mono']">{`${item.company} • ${item.year}`}</p>
            </div>
          </a>
          {rightColumn[i] && (
            <a href={`/work/${rightColumn[i].slug}`} class="project-card group flex flex-col gap-0.5 w-full cursor-none no-underline">
              <div class="h-[250px] w-full rounded-lg overflow-hidden relative transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.03]">
                {rightColumn[i].image ? (
                  <img src={rightColumn[i].image} alt={rightColumn[i].title} class="absolute inset-0 w-full h-full object-cover" />
                ) : (
                  <div class="bg-[#d1d5db] absolute inset-0 flex items-center justify-center">
                    <span class="text-[#9ca3af] text-sm">{getPlaceholderText(rightColumn[i].title)}</span>
                  </div>
                )}
              </div>
              <div class="flex flex-col gap-0.5 text-sm w-full">
                <p class="font-medium text-[#374151] font-['Inter']">{rightColumn[i].title}</p>
                <p class="text-[#6b7280] uppercase font-['Geist_Mono']">{`${rightColumn[i].company} • ${rightColumn[i].year}`}</p>
              </div>
            </a>
          )}
        </>
      ))}
    </div>
  </div>
</div>

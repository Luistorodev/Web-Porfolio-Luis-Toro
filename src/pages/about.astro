---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <div class="bg-[#f8f9fa] flex flex-col min-h-screen w-full">
    <Navbar currentPage="about" />
    <div class="flex flex-col gap-8 md:gap-12 items-center overflow-clip w-full max-w-[1440px] mx-auto py-8 md:py-12 animate-[fadeIn_0.4s_ease-out]">
      <div class="flex flex-col gap-4 px-4 md:px-6 w-full max-w-[968px]">
        <h1 class="font-bold text-[#1f2a37] text-[24px] md:text-[31px] leading-tight font-['Inter']">
          Designing products. Exploring the world. Building new things.
        </h1>
        <p class="text-[#6b7280] text-[13px] leading-tight font-['Inter']">
          A curious creator driven by technology, finance, gaming, travel, and entrepreneurship. Currently exploring how digital and physical products come together through 3D printing and maker culture.
        </p>
      </div>

      <div class="flex flex-col items-start w-full">
        <div class="hidden lg:flex gap-8 justify-center px-6 w-full items-start">
          <div class="flex flex-1 flex-col gap-8 min-w-0">
            <div class="h-[353px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
            <div class="h-[353px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          </div>
          <div class="flex flex-1 flex-col gap-8 min-w-0 h-[842px]">
            <div class="h-[332px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
            <div class="flex-1 min-h-0 w-full rounded-lg bg-[#9ca3af]"></div>
          </div>
          <div class="flex flex-1 flex-col gap-8 min-w-0">
            <div class="h-[353px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
            <div class="h-[332px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          </div>
          <div class="flex flex-1 flex-col gap-8 min-w-0 h-[842px]">
            <div class="flex-1 min-h-0 w-full rounded-lg bg-[#9ca3af]"></div>
            <div class="flex-1 min-h-0 w-full rounded-lg bg-[#9ca3af]"></div>
          </div>
        </div>

        <div class="hidden md:flex lg:hidden gap-8 justify-center px-6 w-full items-start">
          <div class="flex flex-1 flex-col gap-8 min-w-0">
            <div class="h-[353px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
            <div class="h-[332px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
            <div class="h-[353px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
            <div class="h-[332px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          </div>
          <div class="flex flex-1 flex-col gap-8 min-w-0">
            <div class="h-[332px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
            <div class="h-[353px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
            <div class="h-[353px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
            <div class="h-[332px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          </div>
        </div>

        <div class="flex md:hidden flex-col gap-8 px-4 w-full">
          <div class="h-[250px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          <div class="h-[300px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          <div class="h-[220px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          <div class="h-[280px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          <div class="h-[320px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          <div class="h-[240px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          <div class="h-[260px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
          <div class="h-[290px] w-full rounded-lg bg-[#9ca3af] shrink-0"></div>
        </div>
      </div>
    </div>
    <Footer />
  </div>
</Layout>

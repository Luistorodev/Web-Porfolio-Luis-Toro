---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SideProjectsGrid from '../components/SideProjectsGrid.astro';
---

<Layout>
  <div class="bg-[#f8f9fa] flex flex-col min-h-screen w-full">
    <Navbar currentPage="side-projects" />
    <div class="flex flex-col gap-8 md:gap-12 items-center overflow-clip w-full max-w-[1440px] mx-auto py-8 md:py-12 animate-[fadeIn_0.4s_ease-out]">
      <div class="flex flex-col gap-4 px-4 md:px-6 w-full max-w-[968px]">
        <h1 class="font-bold text-[#1f2a37] text-[24px] md:text-[31px] leading-tight font-['Inter']">
          Building products, exploring code, empowering communities
        </h1>
        <p class="text-[#6b7280] text-[13px] leading-tight font-['Inter']">
          I enjoy building products for communities, exploring the limits of code, and experimenting with front-end development. Currently building a personal finance manager.
        </p>
      </div>
      <SideProjectsGrid />
    </div>
    <Footer />
  </div>
</Layout>
